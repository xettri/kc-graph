{
  "name": "kc-graph",
  "version": "0.1.0",
  "description": "AI-optimized code intelligence graph — maps codebases at module/function/variable level for token-efficient AI context retrieval",
  "repository": {
    "type": "git",
    "url": "https://github.com/xettri/kc-graph.git"
  },
  "bugs": {
    "url": "https://github.com/xettri/kc-graph/issues"
  },
  "homepage": "https://github.com/xettri/kc-graph#readme",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "bin": {
    "kc-graph": "./dist/cjs/cli/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.build.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build && npm run typecheck",
    "local:link": "npm run build && npm link",
    "local:unlink": "npm unlink -g kc-graph",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "knowledge-graph",
    "code-intelligence",
    "ai",
    "rag",
    "graph",
    "code-analysis",
    "mcp",
    "claude",
    "ast",
    "typescript"
  ],
  "author": "xettri",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cytoscape": "^3.31.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^1.6.0",
    "vitest": "^3.0.0"
  }
}

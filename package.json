{
  "name": "kc-graph",
  "version": "0.0.1",
  "description": "AI-optimized code intelligence graph — maps codebases at module/function/variable level for token-efficient AI context retrieval",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xettri/kc-graph.git"
  },
  "bugs": {
    "url": "https://github.com/xettri/kc-graph/issues"
  },
  "homepage": "https://github.com/xettri/kc-graph#readme",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "bin": {
    "kc-graph": "dist/cjs/cli/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && pnpm build:esm && pnpm build:cjs",
    "build:esm": "tsc -p tsconfig.build.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "postbuild": "chmod +x dist/cjs/cli/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build && pnpm typecheck",
    "local:link": "pnpm build && npm link",
    "local:unlink": "npm unlink -g kc-graph",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prerelease": "pnpm build && node scripts/prepare-npm.cjs",
    "release": "pnpm prerelease && cd dist && pnpm publish --access public",
    "release:dry": "pnpm release --dry-run",
    "prepare": "husky"
  },
  "keywords": [
    "knowledge-graph",
    "ai",
    "rag",
    "graph",
    "mcp",
    "claude"
  ],
  "author": "xettri",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cytoscape": "^3.31.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^1.6.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.ts": "prettier --write"
  }
}
